@model TravelTripProje.Models.Siniflar.Blog
@{
    ViewBag.Title = "BlogGetir";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<br />
<h2>Blog Güncelle</h2>
<br />
@using (Html.BeginForm("BlogGuncelle", "Admin", FormMethod.Post))
{
    <b>@Html.LabelFor(x => x.ID)</b>
    @Html.TextBoxFor(x => x.ID, new { @class = "form-control", @style = "margin-top:10px; width:500px;", @readonly = "readonly" })
    <br />
    <b>@Html.LabelFor(x => x.Baslik)</b>
    @Html.TextBoxFor(x => x.Baslik, new { @class = "form-control", @style = "margin-top:10px; width:500px;" })
    <br />
    <b>@Html.LabelFor(x => x.Tarih)</b>
    @Html.TextBoxFor(x => x.Tarih, new { @class = "form-control", @style = "margin-top:10px; width:500px;" })
    <br />
    <b>@Html.LabelFor(x => x.Aciklama)</b>
    @Html.TextAreaFor(x => x.Aciklama, new { @class = "form-control", @style = "margin-top:10px; height:300px; width:1000px;" })
    <br />
    <b>@Html.LabelFor(x => x.BlogImage)</b>
    @Html.TextBoxFor(x => x.BlogImage, new { @class = "form-control", @style = "margin-top:10px; width:1000px;" })
    <br />
    <b>@Html.LabelFor(x => x.Durum)</b>
    @Html.DropDownListFor(
        x => x.Durum,
        new SelectList(Enum.GetValues(typeof(TravelTripProje.Models.Siniflar.Blog.BegeniDurum))),
        new { @class = "form-control", @style = "margin-top:10px; width:150px;" }
    )
    <br />
    <button class="btn btn-warning">Güncelle</button>
}
<!DOCTYPE HTML>
<html>
<head>
    <link href="~/web2/css/bootstrap.css" rel='stylesheet' type='text/css' />
    <link href="~/web2/css/style.css" rel='stylesheet' type='text/css' />
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="keywords" content="Personal Blog Responsive web template, Bootstrap Web Templates, Flat Web Templates, Andriod Compatible web template,
	Smartphone Compatible web template, free webdesigns for Nokia, Samsung, LG, SonyErricsson, Motorola web design" />
    <link rel="stylesheet" href="https://www.w3schools.com/w3css/5/w3.css">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Raleway">
    <script type="application/x-javascript"> addEventListener("load", function() { setTimeout(hideURLbar, 0); }, false); function hideURLbar(){ window.scrollTo(0,1); } </script>
    <!----webfonts---->
    <link href='http://fonts.googleapis.com/css?family=Oswald:100,400,300,700' rel='stylesheet' type='text/css'>
    <link href='http://fonts.googleapis.com/css?family=Lato:100,300,400,700,900,300italic' rel='stylesheet' type='text/css'>
</head>
<body>
    <div class="single">
        <div class="container">
            <div class="col-md-8 single-main">
                @foreach (var x in Model.Deger1)
                {
                    <div class="single-grid">
                        <img src="@x.BlogImage" alt="" />
                        <a href="/Blog/BlogDetay/@x.ID" style="display: inline-block; margin-top: 15px;">@x.Baslik</a>
                        <p>
                            @x.Aciklama.Substring(0, 300)...
                        </p>
                    </div>
                }
                @Html.PagedListPager(Model.Deger1, sayfa => Url.Action("Index", new { sayfa }))
            </div>

            <div class="col-md-4 side-content">
                <div class="w3-container w3-padding w3-black">
                    <h4>Son Bloglar</h4>
                </div>
                @foreach (var x in Model.SonBloglar)
                {
                    <ul class="w3-ul w3-hoverable w3-white">
                        <a href="/Blog/BlogDetay/@x.ID" style="text-decoration:none; color:inherit;">
                        <li class="w3-padding-16">
                            <span>@x.Baslik</span>
                        </li>
                        </a>
                    </ul>
                }
            </div>

            <div class="col-md-4 side-content" style="margin-top:20px;">
                <div class="w3-container w3-padding w3-black">
                    <h4>Son Yorumlar</h4>
                </div>
                @foreach (var x in Model.SonYorumlar)
                {
                    <ul class="w3-ul w3-hoverable w3-white">
                        <li class="w3-padding-16">
                            <img src="~/web2/images/avatar.png" alt="Image" class="w3-left w3-margin-right" style="width:50px">
                            <span class="w3-large">@x.KullaniciAdi</span>
                            <br>
                            <span>@x.Yorum</span>
                        </li>
                    </ul>
                }
            </div>
            <div class="clearfix"></div>
        </div>
    </div>
</body>
</html>
@model TravelTripProje.Models.Siniflar.iletisim
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_TestLayout.cshtml";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="https://www.w3schools.com/w3css/5/w3.css">
</head>
<body>
    <!-- Contact Section -->
    <div class="w3-container w3-padding-32" style="text-align: center; width: 1550px; padding-left: 35%;" id="contact">
        <h1 class="w3-border-bottom w3-border-light-grey w3-padding-16">İletişim Bilgileri</h1>
        <p style="font-size:14px;">Soru ve görüşleriniz için aşağıdaki bilgileri doldurarak bizimle iletişime geçebilirisinz.</p>
        <br />
        @using (Html.BeginForm("MesajEkle", "iletisim"))
        {
            @Html.TextBoxFor(x => x.AdSoyad, new { @class = "w3-input w3-border", @type = "text", @placeholder = "Adınız...", @required = "", })
            <br />
            @Html.TextBoxFor(x => x.Mail, new { @class = "w3-input w3-border", @type = "text", @placeholder = "Mail...", @required = "", })
            <br />
            @Html.TextBoxFor(x => x.Konu, new { @class = "w3-input w3-border", @type = "text", @placeholder = "Konu Başlığı...", @required = "", })
            <br />
            @Html.TextBoxFor(x => x.Mesaj, new { @class = "w3-input w3-border", @type = "text", @placeholder = "Mesajınız...", @required = "", })
            <br />
            <button class="w3-button w3-black w3-section" type="submit">
                <i class="fa fa-paper-plane"></i> Mesaj Gönder
            </button>
        }
    </div>

    <!-- Image of location/map -->
    <div class="w3-container" style="text-align: center; width: 100%;">
        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d192698.6461547076!2d28.84737664453487!3d41.005204142416936!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x14caa7040068086b%3A0xe1ccfe98bc01b0d0!2sIstanbul%2C%20%C4%B0stanbul!5e0!3m2!1sen!2str!4v1777396169698!5m2!1sen!2str"
                width="100%"
                height="450"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade">
        </iframe>
    </div>
</body>
</html>
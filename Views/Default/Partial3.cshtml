@using TravelTripProje.Models.Siniflar
@model List<Blog>
<div class="padding">
    <h4>En Popüler 10 Blog</h4>
    <ul class="list list-pad">
        @{int i = 0;}
        @foreach (var x in Model)
        {
            <li class="list-bg">
                <span>@{i++;} @i.</span>
                <a href="/Blog/BlogDetay/@x.ID" title="@x.Baslik">@(x.Baslik.Length > 35 ? x.Baslik.Substring(0,35) + "..." : x.Baslik)</a>
            </li>
        }
    </ul>
    <a href="/Blog/Index" class="link1">Tümünü Görüntüle</a>
</div>